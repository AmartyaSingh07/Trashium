# --- Trashium model API (set on the HOSTING platform: Railway / Render / Fly) --- #
# Optional shared secret. If set, the API requires "Authorization: Bearer <token>".
API_TOKEN=
# Comma-separated CORS origins. Calls come from the Next.js SERVER (estimate.ts is a
# Server Action), so CORS is not strictly required, but lock it down if you ever call
# the API from the browser. Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# --- Set these on VERCEL (Project → Settings → Environment Variables) --- #
# MODEL_API_URL=https://trashium-model.up.railway.app
# MODEL_API_TOKEN=<same value as API_TOKEN above, if you set one>
# MODEL_API_TIMEOUT_MS=2000
