                      <li className="flex items-center gap-1.5">
                        {pickupsDone >= 1 ? <Check className="h-3 w-3 text-[#4A6741]" strokeWidth={3} /> : <span className="inline-block h-3 w-3 rounded-full border border-[#D4C5B0]" />}
