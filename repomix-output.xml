          </h3>
          <RecentPickups pickups={pickups} onCancel={handleCancelPickup} onReschedule={handleReschedulePickup} />
        </Reveal>
      </div>



      {/* Leaderboard segment (Household role gate) — real households only, ranked by Green Credits */}
