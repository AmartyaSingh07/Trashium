@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";

/* ═══════════════════════════════════════════════════════
   TRASHIUM — EARTHY PREMIUM DESIGN SYSTEM
   globals.css — Single source of truth for all visual tokens
   ═══════════════════════════════════════════════════════ */

/* ── STEP 1: Tailwind v4 @theme block ─────────────────── */
@theme inline {
  /* Brand color palette */
  --color-terra:       #C2703D;
  --color-terra-deep:  #A0522D;
  --color-sage:        #8FA37E;
  --color-sage-deep:   #4A6741;
  --color-moss:        #3D5C3A;
  --color-linen:       #F4EFE3;
  --color-parchment:   #EDE5D8;
  --color-sand:        #D9BA8E;
  --color-clay:        #8B5E3C;
  --color-bark:        #2A2218;
  --color-smoke:       #6B5744;
  --color-amber-warm:  #E8A44A;

  /* Font families — references next/font CSS vars injected by layout.tsx.
     --font-devanagari (Hindi) and --font-bengali (Bengali) are appended as
     fallbacks so Indic glyphs render real type instead of tofu boxes; Latin
     fonts have no Indic coverage and silently fall through to these. */
  --font-cormorant: var(--font-cormorant), var(--font-devanagari), var(--font-bengali), Georgia, "Times New Roman", serif;
  --font-syne:      var(--font-syne), var(--font-devanagari), var(--font-bengali), ui-sans-serif, system-ui, sans-serif;
  --font-dm:        var(--font-dm-sans), var(--font-devanagari), var(--font-bengali), ui-sans-serif, system-ui, sans-serif;
  --font-jetbrains: var(--font-jetbrains), var(--font-devanagari), var(--font-bengali), ui-monospace, "Courier New", monospace;

  /* shadcn semantic color mappings to utility classes */
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
}

/* ── STEP 2: shadcn v4 CSS variable overrides ──────────── */
:root {
  /* ── Surface tokens ── */
  --background:           #F4EFE3;   /* linen — page bg */
  --foreground:           #2A2218;   /* bark — primary text */

  --card:                 #EDE5D8;   /* parchment — card bg */
  --card-foreground:      #2A2218;

  --popover:              #F0E9DF;   /* slightly warmer linen */
  --popover-foreground:   #2A2218;

  /* ── Brand tokens ── */
  --primary:              #C2703D;   /* terra */
  --primary-foreground:   #F4EFE3;   /* linen text on terra bg */

  --secondary:            #EDE5D8;   /* parchment */
  --secondary-foreground: #2A2218;

  --accent:               #8FA37E;   /* sage */
  --accent-foreground:    #F4EFE3;

  /* ── Muted / supporting ── */
  --muted:                #E4DDD3;
  --muted-foreground:     #6B5744;   /* smoke */

  /* ── Borders + inputs ── */
  --border:               #D4C5B0;   /* warm sand-ish */
  --input:                #D4C5B0;
  --ring:                 #C2703D;   /* terra focus ring */

  /* ── Feedback ── */
  --destructive:          #C0392B;
  --destructive-foreground: #FAFAFA;

  /* ── Radius ── */
  --radius:               0.625rem;  /* 10px — slightly softer than shadcn default */

  /* ── Trashium custom tokens (non-shadcn) ── */
  --t-glass-bg:      rgba(244,239,227, 0.75);
  --t-glass-border:  rgba(194,112,61, 0.18);
  --t-glass-shadow:  0 8px 32px rgba(42,34,24, 0.08), 0 2px 8px rgba(194,112,61, 0.06);
  --t-shadow-sm:     0 1px 3px rgba(42,34,24, 0.06);
  --t-shadow-md:     0 4px 16px rgba(42,34,24, 0.08), 0 2px 6px rgba(194,112,61, 0.05);
  --t-shadow-lg:     0 12px 40px rgba(42,34,24, 0.12), 0 4px 12px rgba(194,112,61, 0.08);
  --t-shadow-xl:     0 24px 64px rgba(42,34,24, 0.16), 0 8px 20px rgba(194,112,61, 0.10);
  
  --ribbon-opacity: 0.2;
}

.dark {
  --t-linen:       #1A140E;
  --t-parchment:   #221A12;
  --t-cream-glass: rgba(26, 20, 14, 0.82);

  --background: #1A140E;
  --foreground: #F4EFE3;
  --card: #221A12;
  --card-foreground: #F4EFE3;
  --popover: #221A12;
  --popover-foreground: #F4EFE3;
  --primary: #D4885E;
  --primary-foreground: #1A140E;
  --secondary: #2A2218;
  --secondary-foreground: #EDE5D8;
  --muted: #2A2218;
  --muted-foreground: #A09080;
  --accent: #2A2218;
  --accent-foreground: #EDE5D8;
  --destructive: #D45050;
  --border: rgba(194,112,61, 0.22);
  --input: rgba(194,112,61, 0.22);
  --ring: #D4885E;
}

/* ── STEP 3: Base layer overrides ─────────────────────── */
@layer base {
  * { @apply border-border; }

  body {
    @apply bg-linen text-bark antialiased;
    font-family: var(--font-dm);
  }

  h1, h2 {
    font-family: var(--font-cormorant);
    @apply text-bark;
  }

  h3, h4, h5, h6 {
    font-family: var(--font-syne);
    @apply text-bark;
  }
}

/* ── STEP 4: Utility classes ───────────────────────────── */
@layer utilities {

  /* Glass card surface */
  .t-glass-card {
    background: var(--t-glass-bg);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid var(--t-glass-border);
    box-shadow: var(--t-glass-shadow);
    border-radius: 16px;
  }

  /* Typography scale */
  .t-hero {
    font-family: var(--font-cormorant);
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .t-title {
    font-family: var(--font-syne);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.015em;
  }
  .t-heading {
    font-family: var(--font-syne);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .t-body {
    font-family: var(--font-dm);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.65;
  }
  .t-label {
    font-family: var(--font-dm);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .t-stat {
    font-family: var(--font-jetbrains);
    font-size: 2rem;
    font-weight: 500;
  }

  /* Glow utilities for icons */
  .glow-terra {
    filter: drop-shadow(0 0 8px rgba(194,112,61, 0.45));
  }
  .glow-sage {
    filter: drop-shadow(0 0 8px rgba(143,163,126, 0.45));
  }

  /* Gradient text — earthy terracotta */
  .text-gradient-green {
    background: linear-gradient(135deg, var(--color-moss) 0%, var(--color-sage) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-gradient-terra {
    background: linear-gradient(135deg, var(--color-terra) 0%, var(--color-terra-deep) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-gradient-gold {
    background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-clay) 50%, var(--color-terra) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
}

/* ── STEP 5: Component classes ─────────────────────────── */
@layer components {

  /* Grain texture overlay — the tactile paper layer */
  .grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.38;
  }

  /* Status badges */
  .status-pending {
    @apply inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border;
    background: rgba(232, 164, 74, 0.12);
    color: #A0522D;
    border-color: rgba(232, 164, 74, 0.35);
  }
  .status-accepted {
    @apply inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border;
    background: rgba(143,163,126, 0.12);
    color: #3D5C3A;
    border-color: rgba(143,163,126, 0.35);
  }
  .status-completed {
    @apply inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border;
    background: rgba(61, 92, 58, 0.12);
    color: #2D4A2A;
    border-color: rgba(61, 92, 58, 0.30);
  }

  /* Primary CTA button */
  .btn-terra {
    @apply inline-flex items-center justify-center gap-2;
    @apply px-7 py-3 rounded-full;
    @apply bg-terra text-linen;
    font-family: var(--font-syne);
    @apply text-sm font-semibold tracking-wide;
    box-shadow: 0 4px 20px rgba(194,112,61, 0.35);
    transition: all 0.3s ease;
  }
  .btn-terra:hover {
    @apply bg-terra-deep -translate-y-0.5;
    box-shadow: 0 6px 28px rgba(194,112,61, 0.48);
  }
  .btn-terra:active { transform: translateY(0); }

  /* Ghost CTA button */
  .btn-ghost-terra {
    @apply inline-flex items-center justify-center gap-2;
    @apply px-7 py-3 rounded-full border border-terra text-terra;
    font-family: var(--font-syne);
    @apply text-sm font-semibold tracking-wide;
    transition: all 0.3s ease;
  }
  .btn-ghost-terra:hover {
    background: rgba(194,112,61, 0.08);
    @apply -translate-y-0.5;
  }
}

/* ── STEP 6: Keyframe animations ───────────────────────── */
@keyframes credit-shimmer {
  0%, 80%, 100% { background-position: -200% center; }
  88% { background-position: 200% center; }
}

@keyframes fade-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes scale-in {
  from { opacity: 0; transform: scale(0.97); }
  to   { opacity: 1; transform: scale(1); }
}

/* Green Credits shimmer — applied to the credits number element */
.credits-number {
  background: linear-gradient(
    105deg,
    #2A2218 38%,
    #D9BA8E 48%,
    #C2703D 54%,
    #2A2218 64%
  );
  background-size: 300% auto;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: credit-shimmer 4.5s ease-in-out infinite;
}

/* Staggered page load animation helpers */
.animate-fade-up          { animation: fade-up 0.6s ease both; }
.animate-fade-up-delay-1  { animation: fade-up 0.6s 0.1s ease both; }
.animate-fade-up-delay-2  { animation: fade-up 0.6s 0.2s ease both; }
.animate-fade-up-delay-3  { animation: fade-up 0.6s 0.3s ease both; }
.animate-fade-up-delay-4  { animation: fade-up 0.6s 0.4s ease both; }
.animate-scale-in          { animation: scale-in 0.5s ease both; }

/* fadeIn / float — referenced across dashboard, profile, eco-level badge. */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes float  { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
.animate-fadeIn { animation: fadeIn 0.5s ease both; }
.animate-float  { animation: float 3s ease-in-out infinite; }

/* ── Arboreal Ascent — scoped gamification motion (t- prefix; reduced-motion handled globally) ── */
@keyframes t-flame-flicker {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.9; }
  25%      { transform: scale(calc(1 + 0.07 * var(--t-flame-intensity, 0))) rotate(-1.5deg); opacity: 1; }
  50%      { transform: scale(calc(1 - 0.04 * var(--t-flame-intensity, 0))) rotate(0deg); opacity: 0.94; }
  75%      { transform: scale(calc(1 + 0.05 * var(--t-flame-intensity, 0))) rotate(1.5deg); opacity: 1; }
}
.t-flame {
  display: inline-flex;
  transform-origin: 50% 85%;
  filter: drop-shadow(0 0 calc(2px + 7px * var(--t-flame-intensity, 0)) var(--t-flame-color, #C2703D));
  animation: t-flame-flicker 1.5s ease-in-out infinite;
}
.t-flame-dormant { animation: none; opacity: 0.5; filter: grayscale(0.35) brightness(0.95); }

@keyframes t-rise {
  from { opacity: 0; transform: translateY(18px) scale(0.96); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.t-rise { animation: t-rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) both; }

@keyframes t-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(194,112,61, 0); }
  50%      { box-shadow: 0 0 0 4px rgba(194,112,61, 0.12); }
}
.t-pulse { animation: t-pulse 2.1s ease-in-out infinite; }

/* Count-up values: JetBrains Mono + tabular figures so width doesn't jitter while ticking. */
.t-countup { font-family: var(--font-jetbrains), ui-monospace, monospace; font-variant-numeric: tabular-nums; }

/* Daily Grove Ritual — chest unlock, perfect-day leaf burst, weekly-ring reveal. */
@keyframes t-chest-pop {
  0%   { opacity: 0; transform: scale(0.6) translateY(6px); }
  60%  { opacity: 1; transform: scale(1.08); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
.t-chest-pop { animation: t-chest-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both; }

@keyframes t-leaf-burst {
  0%   { opacity: 0; transform: scale(0.4) rotate(-12deg); }
  50%  { opacity: 1; transform: scale(1.3) rotate(8deg); }
  100% { opacity: 0; transform: scale(1.6) rotate(0deg) translateY(-10px); }
}
.t-leaf-burst { animation: t-leaf-burst 1.1s ease-out both; }

@keyframes t-ring-fill {
  from { opacity: 0; transform: scale(0.85); }
  to   { opacity: 1; transform: scale(1); }
}
.t-ring-fill { animation: t-ring-fill 0.6s ease both; }

/* Accessibility: honor reduced-motion globally (covers CSS keyframes + transitions). */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ── S1: MOTION TOKENS — single source for the Editorial Botanical motion language ── */
:root {
  /* Signature easing (already used inline by t-rise/t-ring-fill — now canonical) */
  --ease-botanical: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-botanical-out: cubic-bezier(0.16, 1, 0.3, 1);

  /* Durations — "growth, not flash": slow, organic */
  --motion-fast:   0.4s;
  --motion-base:   0.7s;
  --motion-slow:   1.1s;

  /* Reveal travel distances */
  --motion-rise:   24px;   /* default reveal translateY */
  --motion-rise-sm: 12px;

  /* Stagger cadence */
  --motion-stagger: 0.08s;
}

/* Unified hover/focus language — OPT-IN utilities, applied per element in later sessions.
   Nothing here changes a component's look until a class is added to it. */
@layer utilities {
  .t-lift {
    transition: transform var(--motion-fast) var(--ease-botanical),
                box-shadow var(--motion-fast) var(--ease-botanical);
  }
  .t-lift:hover { transform: translateY(-2px); box-shadow: var(--t-shadow-lg); }
  .t-lift:active { transform: translateY(0); }

  /* Consistent keyboard-focus ring across the redesign (terra, token-driven) */
  .t-focus-ring:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: var(--radius);
  }
}

/* ═══════════════════════════════════════════════════════
   KINETIC TYPOGRAPHY LOADER (components/ui/loading-animation.tsx)
   Full-screen route-loading overlay. Bark backdrop, linen type.
   ═══════════════════════════════════════════════════════ */
.loader-container {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background:
    radial-gradient(120% 120% at 50% 40%, #34291C 0%, #2A2218 55%, #1C160E 100%);
  /* 3D space for the character throws */
  perspective: 1000px;
  transition: opacity 0.5s ease, visibility 0.5s ease;
}

/* Fade-out state for the first-open splash gate */
.loader-container--out {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

/* Soft terra glow behind the type for depth */
.loader-container .loader-glow {
  position: absolute;
  width: 60vmin;
  height: 60vmin;
  border-radius: 9999px;
  background: radial-gradient(circle, rgba(194, 112, 61, 0.22) 0%, rgba(194, 112, 61, 0) 70%);
  filter: blur(8px);
  pointer-events: none;
  animation: loader-glow-breathe 4s ease-in-out infinite;
}

@keyframes loader-glow-breathe {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50%      { opacity: 1;   transform: scale(1.08); }
}

.loader-container .loader-text {
  position: relative;
  transform-style: preserve-3d;
  color: #F4EFE3; /* linen */
  letter-spacing: 0.04em;
  text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
  margin: 0;
}

.loader-container .char {
  display: inline-block;
  opacity: 0;
  will-change: transform, opacity;
  transform-style: preserve-3d;
  /* Tint the leading edge of each glyph toward terra for brand warmth */
  background: linear-gradient(180deg, #F4EFE3 0%, #F4EFE3 60%, #E8A44A 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.loader-container .char--space {
  background: none;
  -webkit-text-fill-color: initial;
}

@keyframes fly-in {
  from {
    opacity: 0;
    transform: var(--transform-from);
  }
  to {
    opacity: 1;
    transform: translateZ(0) rotateX(0) rotateY(0);
  }
}

@keyframes fly-out {
  from {
    opacity: 1;
    transform: translateZ(0) rotateX(0) rotateY(0);
  }
  to {
    opacity: 0;
    transform: var(--transform-to);
  }
}

/* fly-in / fly-out share a single 1s run; play-state toggled per-char in JS */
.loader-container .char {
  animation-duration: 1s;
  animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  animation-fill-mode: forwards;
}

/* Reduced motion: no 3D throws — chars are placed opaque and phrases cross-fade.
   The global reduce block above already neutralizes durations; this guarantees
   characters remain visible rather than stuck at opacity 0. */
@media (prefers-reduced-motion: reduce) {
  .loader-container .char {
    opacity: 1 !important;
    animation: none !important;
    transform: none !important;
  }
  .loader-container .loader-glow {
    animation: none !important;
  }
}
