# Trashium — environment variable template.
# Copy to `.env.local` and fill in real values. NEVER commit real secrets.
# `.env.local` is gitignored; this template (names only) is intentionally tracked.

# --- Supabase (required) -----------------------------------------------------
# The anon key is public by design (ships in the frontend) — it is only safe
# once Row Level Security backs it. See SECURITY_AUDIT_PRELAUNCH.md #4.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry (optional — Sentry stays off when the DSN is unset) --------------
# The DSN is public by design (it only says where to send events).
# SENTRY_AUTH_TOKEN is a build-time secret for source-map upload — never commit.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Local scripts only (NOT used by the Next.js app) ------------------------
# Consumed by seed-crew-accounts.mjs. The service-role key bypasses RLS —
# keep it out of the app bundle and out of git entirely.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Live ML inference API (optional) ----------------------------------------
# If set, pickup quotes call this service's /predict endpoint; if unset, the app
# falls back to the published rates in the Supabase price_estimates table.
MODEL_API_URL=
MODEL_API_TOKEN=
MODEL_API_TIMEOUT_MS=2000
